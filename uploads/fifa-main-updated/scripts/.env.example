# Копирай този файл като .env и сложи своя истински API ключ от api-football.com
# Dashboard -> My Access -> API Key (RapidAPI или директно api-sports.io)
API_FOOTBALL_KEY=твоят_ключ_тук

# Сезон на турнира (винаги 2026 за това световно)
SEASON=2026

# League ID за World Cup в api-football.com (по подразбиране 1)
LEAGUE_ID=1
